### 4. ELIMINAR ÓRDENES (DELETE)
### ============================================

### 4.1 Eliminar orden ORD001
DELETE http://localhost:8080/softlearning/orders/ORD001

### 4.2 Eliminar orden ORD002
DELETE http://localhost:8080/softlearning/orders/ORD002

### 4.3 Eliminar orden ORD003
DELETE http://localhost:8080/softlearning/orders/ORD003

### ============================================
### 5. CASOS DE ERROR - VALIDACIÓN DE ESTADOS
### ============================================

### 5.1 ERROR: Intentar poner physicalData sin tener paymentDate (status debe ser CONFIRMED)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Intento de poner physicalData sin paymentDate",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "physicalData": "weight:2.5;height:5.0;width:35.0;depth:25.0;isFragile:true",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 5.2 ERROR: Intentar poner deliveryDate sin tener physicalData (status debe ser FORTHCOMMING)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Intento de poner deliveryDate sin physicalData",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "paymentDate": "2026-04-15 18:50:00",
  "deliveryDate": "2026-04-18 14:30:00",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 5.3 ERROR: Intentar poner finishDate sin tener deliveryDate (status debe ser DELIVERED)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Intento de poner finishDate sin deliveryDate",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "paymentDate": "2026-04-15 18:50:00",
  "physicalData": "weight:2.5;height:5.0;width:35.0;depth:25.0;isFragile:true",
  "finishDate": "2026-04-18 16:45:00",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### =============================================
### 6 FLUJO CORRECTO (Sin errores - Secuencia correcta de estados):
### =============================================
### 6.1: Crear orden (estado CREATED)
POST http://localhost:8080/softlearning/orders
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Orden para prueba de flujo correcto",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 6.2: Poner paymentDate (status: CREATED → CONFIRMED)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Orden para prueba de flujo correcto",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "paymentDate": "2026-04-16 19:00:00",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 6.3: Poner physicalData (status: CONFIRMED → FORTHCOMMING)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Orden para prueba de flujo correcto",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "paymentDate": "2026-04-16 19:00:00",
  "physicalData": "weight:2.5;height:5.0;width:35.0;depth:25.0;isFragile:true",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 6.4: Poner deliveryDate (status: FORTHCOMMING → DELIVERED)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
  "description": "Orden para prueba de flujo correcto",
  "address": "Calle Mayor 10",
  "name": "Juan Perez",
  "phone": "600112233",
  "paymentDate": "2026-04-16 19:00:00",
  "physicalData": "weight:2.5;height:5.0;width:35.0;depth:25.0;isFragile:true",
  "deliveryDate": "2026-04-18 14:30:00",
  "shopcartDetails": [
    {
      "bookId": 1,
      "amount": 2,
      "price": 39.99,
      "discount": 0.10
    }
  ]
}

### 6.5: Poner finishDate (status: DELIVERED → FINISHED)
PUT http://localhost:8080/softlearning/orders/ORD001
Content-Type: application/json
Accept: application/json

{
  "ref": "ORD001",
  "idClient": 1001,
  "startDate": "2026-04-16 18:30:00",
